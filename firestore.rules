rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && getUserRole() == "admin";
    }

    function isCustomer() {
      return request.auth != null && getUserRole() == "customer";
    }

    match /boats/{boatId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if isCustomer() && request.auth.uid == request.resource.data.userId;
      // hay que limitar la create de reviews por seguridad
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read, write: if isAdmin();
      allow read: if isCustomer() && request.auth.uid == resource.data.userId;
    }

    match /maintenance_blocks/{maintenanceId} {
      allow read, write: if isAdmin();
    }
  }
}