rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && getUserRole() == "admin";
    }

    function isCustomer() {
      return request.auth != null && getUserRole() == "customer";
    }

    match /boats/{boatId} {
      allow read: if request.auth != null;
      allow write, create, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if isCustomer() && request.auth.uid == request.resource.data.userId;
      // hay que limitar la create de reviews por seguridad
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read, write: if isAdmin();
      allow read: if isCustomer() && request.auth.uid == resource.data.userId;
      allow update: if isCustomer()
        && request.auth.uid == resource.data.userId
        && request.resource.data.status == 'cancelada'
        && (resource.data.status == 'pendiente' || resource.data.status == 'confirmada');
    }

    match /booking_date_locks/{lockId} {
      allow read, write: if isAdmin();
      allow delete: if isCustomer()
        && get(/databases/$(database)/documents/bookings/$(resource.data.booking_id)).data.user_id == request.auth.uid;
    }

    match /maintenance_blocks/{maintenanceId} {
      allow read, write: if isAdmin();
    }

  }
}